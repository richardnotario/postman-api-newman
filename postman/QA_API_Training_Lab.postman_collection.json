        {
          "name": "POST Create Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/patients",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "patients"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Lia\",\n  \"lastName\": \"Mendoza\",\n  \"dateOfBirth\": \"2019-03-10\",\n  \"gender\": \"Female\",\n  \"contactNumber\": \"09179998888\",\n  \"email\": \"{{newPatientEmail}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const uniqueEmail = `training.patient.${Date.now()}@example.com`;",
                  "pm.environment.set(\"newPatientEmail\", uniqueEmail);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201\", function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Created patient has ID\", function () { pm.expect(json.id).to.be.a(\"number\"); });",
                  "pm.test(\"Created patient email matches request\", function () { pm.expect(json.email).to.eql(pm.environment.get(\"newPatientEmail\")); });",
                  "pm.environment.set(\"createdPatientId\", json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Create Patient - Duplicate Email",
