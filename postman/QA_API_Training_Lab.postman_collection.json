                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "appointments"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200 with valid token\", function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Appointments response is an array\", function () { pm.expect(json).to.be.an(\"array\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Create Appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/appointments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "appointments"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"doctorId\": 1,\n  \"appointmentDate\": \"{{futureAppointmentDate}}\",\n  \"notes\": \"Postman/Newman-created appointment\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = new Date();",
                  "d.setDate(d.getDate() + 7);",
                  "pm.environment.set(\"futureAppointmentDate\", d.toISOString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201\", function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Created appointment has ID\", function () { pm.expect(json.id).to.be.a(\"number\"); });",
                  "pm.test(\"Created appointment has SCHEDULED status\", function () { pm.expect(json.status).to.eql(\"SCHEDULED\"); });",
                  "pm.environment.set(\"appointmentId\", json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Create Appointment - Past Date",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/appointments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "appointments"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"doctorId\": 1,\n  \"appointmentDate\": \"2024-01-01T09:30:00.000Z\",\n  \"notes\": \"Past date should fail\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 400 for past appointment date\", function () { pm.response.to.have.status(400); });"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH Update Appointment Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "appointments",
                "{{appointmentId}}",
                "status"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Appointment status is CONFIRMED\", function () { pm.expect(json.status).to.eql(\"CONFIRMED\"); });"
                ]
              }
            }
          ]
        }
      ]
