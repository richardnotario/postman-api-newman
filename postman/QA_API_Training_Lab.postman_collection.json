  "item": [
    {
      "name": "01 Public Endpoints",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Response is JSON\", function () { pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\"); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Health status is ok\", function () { pm.expect(json.status).to.eql(\"ok\"); });",
                  "pm.test(\"Health response has service and timestamp\", function () { pm.expect(json).to.have.property(\"service\"); pm.expect(json).to.have.property(\"timestamp\"); });",
                  "pm.test(\"Response time is below 3000ms\", function () { pm.expect(pm.response.responseTime).to.be.below(3000); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Clinics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/clinics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "clinics"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Clinics response is an array\", function () { pm.expect(json).to.be.an(\"array\"); });",
                  "pm.test(\"At least one clinic exists\", function () { pm.expect(json.length).to.be.greaterThan(0); });",
                  "pm.test(\"Clinic has expected fields\", function () { const c = json[0]; pm.expect(c).to.have.property(\"id\"); pm.expect(c).to.have.property(\"name\"); pm.expect(c).to.have.property(\"city\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Doctors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/doctors",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "doctors"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Doctors response is an array\", function () { pm.expect(json).to.be.an(\"array\"); });",
                  "pm.test(\"At least one doctor exists\", function () { pm.expect(json.length).to.be.greaterThan(0); });",
                  "pm.test(\"Doctor has expected fields\", function () { const d = json[0]; pm.expect(d).to.have.property(\"id\"); pm.expect(d).to.have.property(\"fullName\"); pm.expect(d).to.have.property(\"specialty\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Doctors by Specialty",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/doctors?specialty={{specialty}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "doctors"
              ],
              "query": [
                {
                  "key": "specialty",
                  "value": "{{specialty}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Filtered doctors response is an array\", function () { pm.expect(json).to.be.an(\"array\"); });",
                  "pm.test(\"All returned doctors match requested specialty\", function () { const expected = pm.environment.get(\"specialty\"); json.forEach(function (doctor) { pm.expect(doctor.specialty).to.eql(expected); }); });"
                ]
              }
            }
          ]
        }
      ]
